<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Тест на фишинг</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #000000;
            color: white;
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            text-align: center;
        }
        
        .red-text {
            color: #ff0000;
            font-size: 4.5rem;
            font-weight: bold;
            margin-bottom: 20px;
            text-shadow: 0 0 10px #ff0000;
        }
        
        .sad-face {
            font-size: 6rem;
            margin: 0 20px 20px 20px;
            line-height: 1;
        }
        
        .message {
            color: #ffffff;
            font-size: 2.2rem;
            margin-top: 10px;
        }
        
        .container {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="red-text">попался</div>
        <div class="sad-face">☹️</div>
    </div>
    
    <div class="message">тест на фишинг провален</div>
</body>
</html>
